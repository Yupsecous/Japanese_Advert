{
  "cli": {
    "version": ">= 5.0.0",
    "appVersionSource": "local"
  },
  "build": {
    "preview": {
      "android": {
        "buildType": "apk"
      },
      "distribution": "internal",
      "env": {
        "BACKEND_URL": "https://REPLACE-WITH-YOUR-VERCEL-URL.vercel.app"
      },
      "channel": "preview"
    },
    "production": {
      "android": {
        "buildType": "app-bundle"
      },
      "distribution": "store",
      "env": {
        "BACKEND_URL": "https://REPLACE-WITH-YOUR-VERCEL-URL.vercel.app"
      },
      "channel": "production"
    }
  },
  "submit": {
    "production": {}
  }
}
