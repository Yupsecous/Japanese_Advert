# Backend secrets. Copy to .env.local for `vercel dev` and set the same
# vars in the Vercel project settings for production. NEVER commit .env.local.

# Shared sign-in credentials. Username is "IAmThatIAm" by default (matches
# the web demo). The password is checked server-side; clients never see it.
AUTH_USERNAME=IAmThatIAm
AUTH_PASSWORD=The FIrst Dream

# 32+ byte secret used to sign session JWTs. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_JWT_SECRET=replace-with-a-strong-random-secret-at-least-32-bytes

# Token lifetime in seconds. 12h is reasonable for an internal tool.
AUTH_TOKEN_TTL_SECONDS=43200

# Provider API keys — set in Vercel project settings, NOT in .env.local
# unless you really want to test against real providers from your laptop.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
FAL_API_KEY=
ELEVENLABS_API_KEY=

# Soft cost cap per session token (USD). Server tracks cumulative spend
# in-memory and rejects calls that would exceed this. 0 disables the cap.
SESSION_COST_CAP_USD=20
