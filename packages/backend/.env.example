# Backend env. Copy to .env.local (gitignored) for local dev, and set the
# same vars on the VPS (e.g. an EnvironmentFile for the systemd unit).
# NEVER commit real secrets.

# ── Server ──────────────────────────────────────────────────────────────────
PORT=3001
# Public origin of the deployed site. REQUIRED in production: it scopes CORS,
# is used to build email + OAuth callback links, and switches session cookies
# to Secure. Leave UNSET in local dev (http://localhost via the Vite proxy).
PUBLIC_ORIGIN=https://personifyads.online

# ── Database (PostgreSQL) ─────────────────────────────────────────────────────
DATABASE_URL=postgres://advert:CHANGE_ME@localhost:5432/advert

# ── Web sessions (email/password + Google) ────────────────────────────────────
# 32+ byte random string signing the short-lived OAuth state/PKCE cookies.
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_COOKIE_SECRET=replace-with-a-strong-random-secret-at-least-32-bytes
# Web session lifetime (seconds). Default 30 days.
SESSION_TTL_SECONDS=2592000

# ── Google OAuth (Sign in with Google) ────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://personifyads.online/api/auth/google/callback

# ── Email (Resend) — verification + password-reset links ──────────────────────
RESEND_API_KEY=
# Must be a Resend-verified sending domain.
EMAIL_FROM=PersonifyAds <noreply@personifyads.online>

# ── Legacy shared-credential login (Android app, Bearer JWT) — keep ───────────
AUTH_USERNAME=IAmThatIAm
AUTH_PASSWORD=The FIrst Dream
# 32+ byte secret signing the Android Bearer JWTs.
AUTH_JWT_SECRET=replace-with-a-strong-random-secret-at-least-32-bytes
AUTH_TOKEN_TTL_SECONDS=43200

# ── Provider API keys (server-held; web + Android never see these) ────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
FAL_API_KEY=
ELEVENLABS_API_KEY=

# Soft per-user cost cap (USD). Server tracks cumulative spend and rejects
# calls that would exceed this. 0 disables.
SESSION_COST_CAP_USD=20
